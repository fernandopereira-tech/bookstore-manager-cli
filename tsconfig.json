{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist", 
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
  
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
    "declaration": false,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}